{
  "compilerOptions": {
    "esModuleInterop": true,
    "target": "ES2022",
    "module": "ESNext",
    "declaration": true,
    "sourceMap": true,
    "strict": true,
    "noUnusedLocals": false,
    "outDir": "build",
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "lib": ["es2022",],
    "noEmit": true
  },
  "include": ["./src", "./tests"],
}
